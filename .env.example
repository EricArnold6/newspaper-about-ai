# Copy this file to .env and fill in your actual API keys for local development.
# Never commit .env to version control.
#
# Get your NewsAPI key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# LLM service — choose ONE of the two options below:

# Option 1: OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Option 2: GitHub personal access token — uses GitHub Models (Copilot) instead of OpenAI.
# Create a token at https://github.com/settings/tokens (no special scopes needed for Models).
# If OPENAI_API_KEY is set, it takes priority over GITHUB_TOKEN.
# GITHUB_TOKEN=your_github_token_here
